# Google Gemini API (free) - get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alpha Vantage (free) - get at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# FRED API (free) - get at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub (free) - get at: https://finnhub.io/register
FINNHUB_KEY=your_finnhub_key_here

# Gmail settings - use an App Password (not your real password)
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
RECIPIENT_EMAIL=your_email@gmail.com
